# Copy to .env and fill in. Do NOT commit .env (it is gitignored).

# Postgres connection string (Neon, Supabase, local Postgres, etc.)
DATABASE_URL=

# Auth.js session-signing secret (required at runtime).
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public site URL — used for absolute links in RSS / OpenGraph metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin bootstrap — read only by `npm run admin:create`, never at runtime.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel cron auth — when set, the LoginAttempt sweep route
# (/api/cron/sweep-login-attempts) requires `Authorization: Bearer <CRON_SECRET>`.
# Vercel sends it automatically for scheduled invocations. Leave unset locally.
# Generate with: openssl rand -hex 32
CRON_SECRET=
